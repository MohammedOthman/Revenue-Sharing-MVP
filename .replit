run = "bash replit-run.sh"
entrypoint = "revenue-share-platform/backend/src/server.js"
modules = ["nodejs-20", "postgresql-16"]
hidden = [".config", "**/node_modules"]

[nix]
channel = "stable-24_05"

[env]
PORT = "5000"

# The Vite dev server is the public webview; it proxies /api to the backend,
# so the backend port stays internal.
[[ports]]
localPort = 3000
externalPort = 80

[deployment]
run = ["bash", "replit-run.sh"]
deploymentTarget = "cloudrun"
