# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=change-me

# PostgreSQL - option A: single connection string (takes precedence).
# Replit's built-in PostgreSQL sets this automatically.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# PostgreSQL - option B: individual settings for a local instance.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=revenue_share
DB_USER=postgres
DB_PASSWORD=postgres
